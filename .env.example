# ============================================
# ForgeLink Environment Variables
# ============================================
# Copy this file to .env and fill in the values
# NEVER commit .env to git
# ============================================

# -------------------- Django API --------------------
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Django database (PostgreSQL)
DJANGO_DB_HOST=postgres
DJANGO_DB_PORT=5432
DJANGO_DB_NAME=forgelink
DJANGO_DB_USER=forgelink
DJANGO_DB_PASSWORD=forgelink_dev_password

# -------------------- TDengine (Time-series) --------------------
TDENGINE_HOST=tdengine
TDENGINE_PORT=6041
TDENGINE_USER=root
TDENGINE_PASSWORD=taosdata
TDENGINE_DATABASE=forgelink_telemetry

# -------------------- Spring IDP --------------------
IDP_DB_HOST=postgres
IDP_DB_PORT=5432
IDP_DB_NAME=idp
IDP_DB_USER=idp
IDP_DB_PASSWORD=idp_dev_password

# JWT configuration
IDP_JWT_PRIVATE_KEY_PATH=/app/secrets/jwt-private.pem
IDP_JWT_PUBLIC_KEY_PATH=/app/secrets/jwt-public.pem
IDP_JWT_EXPIRY_HOURS=24
IDP_REFRESH_EXPIRY_DAYS=30
IDP_JWT_ISSUER=forgelink-idp

# -------------------- Spring Notification Service --------------------
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# -------------------- EMQX (MQTT Broker) --------------------
EMQX_ADMIN_USERNAME=admin
EMQX_ADMIN_PASSWORD=forgelink_emqx_admin
EMQX_MQTT_USERNAME=bridge
EMQX_MQTT_PASSWORD=bridge_dev_password

# -------------------- Kafka --------------------
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_CONSUMER_GROUP_ID=forgelink
KAFKA_PARTITIONS=3
KAFKA_REPLICATION_FACTOR=1

# -------------------- RabbitMQ --------------------
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=forgelink
RABBITMQ_PASSWORD=forgelink_rabbitmq_dev
RABBITMQ_VHOST=/

# -------------------- Redis --------------------
# DB0: Django sessions + rate limiting
# DB1: Spring IDP token blacklist
# DB2: Celery broker + result backend
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DJANGO_DB=0
REDIS_IDP_DB=1
REDIS_CELERY_DB=2

# -------------------- MinIO (S3-compatible storage) --------------------
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=forgelink_minio
MINIO_SECRET_KEY=forgelink_minio_secret
MINIO_USE_SSL=false
MINIO_BUCKET_BACKUPS=backups
MINIO_BUCKET_MODELS=ai-models

# -------------------- Observability --------------------
JAEGER_AGENT_HOST=jaeger
JAEGER_AGENT_PORT=6831
JAEGER_ENDPOINT=http://jaeger:14268/api/traces

PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=forgelink_grafana_dev

# -------------------- Slack Integration --------------------
# Stub values for local dev - replace with real tokens in production
SLACK_BOT_TOKEN=xoxb-stub-token
SLACK_SIGNING_SECRET=stub-signing-secret
SLACK_ALERTS_CHANNEL=factory-alerts
SLACK_OPS_CHANNEL=factory-ops
SLACK_INFRA_CHANNEL=infra-alerts

# -------------------- Email --------------------
# Console backend for dev - configure SMTP for production
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
EMAIL_FROM=alerts@forgelink.local

# -------------------- FCM (Firebase Cloud Messaging) --------------------
# Stub for dev - provide real credentials for production
FCM_SERVER_KEY=stub-fcm-key
FCM_PROJECT_ID=forgelink-stub

# -------------------- Seed Data --------------------
SEED_ADMIN_EMAIL=admin@forgelink.local
SEED_ADMIN_PASSWORD=Admin@ForgeLink2026!
SEED_PLANT_NAME=steel-plant-kigali

# -------------------- Factory Configuration --------------------
FACTORY_TIMEZONE=Africa/Kigali
FACTORY_DAILY_SUMMARY_HOUR=8

# -------------------- Rate Limiting --------------------
RATE_LIMIT_PER_USER=60/minute
RATE_LIMIT_PER_ENDPOINT=600/minute

# -------------------- Telemetry Batching --------------------
TELEMETRY_BATCH_SIZE=500
TELEMETRY_BATCH_TIMEOUT_MS=1000
