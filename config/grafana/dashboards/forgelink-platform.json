{
  "annotations": {
    "list": []
  },
  "description": "ForgeLink platform overview — HTTP request volume, latency, error rate, and MQTT-bridge throughput across the wired services.",
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Requests per second served by the Django integration hub, keyed by HTTP method.",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": { "showLegend": true, "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (method) (rate(django_http_requests_total_by_method_total[1m]))",
          "legendFormat": "{{method}}",
          "refId": "A"
        }
      ],
      "title": "Django API — requests per second by method",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "p50 / p95 / p99 request latency including Django middleware.",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": {
        "legend": { "showLegend": true, "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(django_http_requests_latency_including_middlewares_seconds_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(django_http_requests_latency_including_middlewares_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(django_http_requests_latency_including_middlewares_seconds_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "title": "Django API — request latency percentiles",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "HTTP 4xx + 5xx response rate. Spikes here usually correlate with authentication failures or upstream dependency issues.",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "options": {
        "legend": { "showLegend": true, "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "expr": "sum by (status) (rate(django_http_responses_total_by_status_total{status=~\"4..|5..\"}[1m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "title": "Django API — error response rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "MQTT messages processed by the bridge per second, per Kafka topic — the primary telemetry-throughput signal.",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "options": {
        "legend": { "showLegend": true, "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "expr": "sum by (kafka_topic) (rate(mqtt_messages_processed_total[1m]))",
          "legendFormat": "{{kafka_topic}}",
          "refId": "A"
        }
      ],
      "title": "MQTT bridge — messages/sec to Kafka (by topic)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "DLQ rate and parse-error rate from the MQTT bridge. Any sustained non-zero value here means the telemetry pipeline has drift between producer and consumer.",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "id": 5,
      "options": {
        "legend": { "showLegend": true, "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "expr": "rate(mqtt_parse_errors_total[1m])",
          "legendFormat": "parse_errors",
          "refId": "A"
        },
        {
          "expr": "rate(kafka_publish_errors_total[1m])",
          "legendFormat": "kafka_publish_errors",
          "refId": "B"
        }
      ],
      "title": "MQTT bridge — error & DLQ rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Spring IDP HTTP requests rate — login/refresh/JWKS endpoint traffic.",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "id": 6,
      "options": {
        "legend": { "showLegend": true, "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "expr": "sum by (uri, status) (rate(http_server_requests_seconds_count{application=\"forgelink-idp\"}[1m]))",
          "legendFormat": "{{uri}} {{status}}",
          "refId": "A"
        }
      ],
      "title": "Spring IDP — requests by URI & status",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
